# ──────────────────────────────────────────────────────────────
# server/proxy.js + server/sync.js 환경변수 템플릿
# 실제 값은 .env 파일에 채워서 같은 디렉토리에 두세요 (.env는 git에 안 올라감)
# ──────────────────────────────────────────────────────────────

# 프록시 LISTEN 설정
PROXY_PORT=3002
PROXY_HOST=127.0.0.1

# CORS 허용 origin (콤마 구분, * 면 모든 허용)
# 예: https://order-manager-kappa.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=*

# 프록시 호출 시 헤더 검증 토큰 (비워두면 비활성)
# 32자 이상 랜덤문자열 권장 (생성: openssl rand -hex 32)
PROXY_TOKEN=

# 네이버 커머스 API 자격증명 — 브랜드별
PALEO_APP_ID=
PALEO_APP_SECRET=
COCOEL_APP_ID=
COCOEL_APP_SECRET=

# sync.js 에서만 사용 (Supabase 직접 접근)
SUPABASE_URL=
SUPABASE_KEY=
PROXY_BASE=http://127.0.0.1:3002
